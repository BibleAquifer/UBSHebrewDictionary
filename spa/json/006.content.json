der-top: 1px solid #eee; padding-top: 0.4em; }\n.fn-ref-verse { font-weight: bold; margin-right: 0.3em; }\nspan[data-bntype=\"bibleReference\"] { color: #1a5fb4; }\n</style><h1 id=\"001909000000000\" class=\"lex-lemma\" lang=\"he\" dir=\"rtl\">וַשְׁתִּי</h1><p class=\"lex-entry-meta\"><span class=\"lex-lemma-meta\" lang=\"he\" dir=\"rtl\">וַשְׁתִּי</span> (<span class=\"lex-strong\">H2060</span>)</p><div class=\"lex-base-form\"><p class=\"lex-base-form-head\">name</p><div class=\"lex-meaning\" data-id=\"001909001001000\"><p class=\"lex-domains\"><span class=\"lex-domain\">Nombres de personas</span></p><p class=\"lex-sense\"><span class=\"lex-glosses\"><span class=\"lex-gloss\">Vasti</span></span> <span class=\"lex-def\">= mujer; ► esposa de <span class=\"lex-link\" data-lemma=\"אֲחַשְׁוֵרֹושׁ\">Asuero</span>, rey de <span class=\"lex-link\" data-lemma=\"פָּרַס\">Persia</span>; fue depuesta como reina de Persia y reemplazada por <span class=\"lex-link\" data-lemma=\"אֶסְתֵּר\">Esther</span></span></p><p class=\"lex-refs\"><a href=\"https://ref.ly/Esth1:9\">EST 1:9</a> · <a href=\"https://ref.ly/Esth1:11\">EST 1:11</a> · <a href=\"https://ref.ly/Esth1:12\">EST 1:12</a> · <a href=\"https://ref.ly/Esth1:15\">EST 1:15</a> · <a href=\"https://ref.ly/Esth1:16\">EST 1:16</a> · <a href=\"https://ref.ly/Esth1:17\">EST 1:17</a> · <a href=\"https://ref.ly/Esth1:19\">EST 1:19</a> · <a href=\"https://ref.ly/Esth2:1\">EST 2:1</a> · <a href=\"https://ref.ly/Esth2:4\">EST 2:4</a> · <a href=\"https://ref.ly/Esth2:17\">EST 2:17</a></p></div></div><p class=\"lex-attribution\"><span class=\"lex-author\">Reinier de Blois</span></p>",
